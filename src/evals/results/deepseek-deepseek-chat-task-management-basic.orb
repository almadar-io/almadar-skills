{
  "name": "Task Manager",
  "version": "1.0.0",
  "orbitals": [
    {
      "name": "Task Management",
      "entity": {
        "name": "Task",
        "collection": "tasks",
        "fields": [
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "enum",
            "values": [
              "pending",
              "active",
              "done"
            ]
          },
          {
            "name": "priority",
            "type": "enum",
            "values": [
              "low",
              "medium",
              "high"
            ]
          }
        ]
      },
      "traits": [
        {
          "name": "TaskInteraction",
          "category": "interaction",
          "linkedEntity": "Task",
          "emits": [
            {
              "event": "INIT",
              "scope": "internal"
            }
          ],
          "stateMachine": {
            "states": [
              {
                "name": "Browsing",
                "isInitial": true
              },
              {
                "name": "Creating"
              },
              {
                "name": "Editing"
              },
              {
                "name": "Viewing"
              },
              {
                "name": "Deleting"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create Task"
              },
              {
                "key": "VIEW",
                "name": "View Task",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "EDIT",
                "name": "Edit Task",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "DELETE",
                "name": "Delete Task",
                "payload": [
                  {
                    "name": "id",
                    "type": "string"
                  }
                ]
              },
              {
                "key": "SAVE",
                "name": "Save Task",
                "payload": [
                  {
                    "name": "data",
                    "type": "object"
                  }
                ]
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              }
            ],
            "transitions": [
              {
                "from": "Browsing",
                "to": "Browsing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "stack",
                      "direction": "vertical",
                      "gap": "lg",
                      "children": [
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "justify": "between",
                          "align": "center",
                          "children": [
                            {
                              "type": "typography",
                              "variant": "h1",
                              "text": "Task Manager",
                              "color": "var(--color-foreground)"
                            },
                            {
                              "type": "button",
                              "label": "New Task",
                              "event": "CREATE",
                              "variant": "primary"
                            }
                          ]
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "wrap": true,
                          "children": [
                            {
                              "type": "box",
                              "padding": "md",
                              "bg": "var(--color-card)",
                              "border": true,
                              "borderColor": "var(--color-border)",
                              "rounded": "var(--radius-lg)",
                              "shadow": "var(--shadow-sm)",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "text": "Total Tasks",
                                  "color": "var(--color-muted-foreground)"
                                },
                                {
                                  "type": "typography",
                                  "variant": "h2",
                                  "text": "@count",
                                  "color": "var(--color-foreground)"
                                }
                              ]
                            },
                            {
                              "type": "box",
                              "padding": "md",
                              "bg": "var(--color-card)",
                              "border": true,
                              "borderColor": "var(--color-border)",
                              "rounded": "var(--radius-lg)",
                              "shadow": "var(--shadow-sm)",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "text": "Pending",
                                  "color": "var(--color-muted-foreground)"
                                },
                                {
                                  "type": "badge",
                                  "text": "@count:status=pending",
                                  "variant": "warning"
                                }
                              ]
                            },
                            {
                              "type": "box",
                              "padding": "md",
                              "bg": "var(--color-card)",
                              "border": true,
                              "borderColor": "var(--color-border)",
                              "rounded": "var(--radius-lg)",
                              "shadow": "var(--shadow-sm)",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "text": "Active",
                                  "color": "var(--color-muted-foreground)"
                                },
                                {
                                  "type": "badge",
                                  "text": "@count:status=active",
                                  "variant": "primary"
                                }
                              ]
                            },
                            {
                              "type": "box",
                              "padding": "md",
                              "bg": "var(--color-card)",
                              "border": true,
                              "borderColor": "var(--color-border)",
                              "rounded": "var(--radius-lg)",
                              "shadow": "var(--shadow-sm)",
                              "children": [
                                {
                                  "type": "typography",
                                  "variant": "caption",
                                  "text": "Completed",
                                  "color": "var(--color-muted-foreground)"
                                },
                                {
                                  "type": "badge",
                                  "text": "@count:status=done",
                                  "variant": "success"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "entity-table",
                          "entity": "Task",
                          "columns": [
                            "title",
                            "status",
                            "priority"
                          ],
                          "searchable": true,
                          "itemActions": [
                            {
                              "label": "View",
                              "event": "VIEW"
                            },
                            {
                              "label": "Edit",
                              "event": "EDIT"
                            },
                            {
                              "label": "Delete",
                              "event": "DELETE",
                              "variant": "danger"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "Browsing",
                "to": "Creating",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Task",
                      "fields": [
                        "title",
                        "status",
                        "priority"
                      ],
                      "submitEvent": "SAVE",
                      "cancelEvent": "CANCEL"
                    }
                  ]
                ]
              },
              {
                "from": "Creating",
                "to": "Browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Task",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "INIT"
                  ]
                ]
              },
              {
                "from": "Creating",
                "to": "Browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "Creating",
                "to": "Browsing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "Browsing",
                "to": "Viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "drawer",
                    {
                      "type": "entity-detail",
                      "entity": "Task",
                      "fields": [
                        "title",
                        "status",
                        "priority"
                      ],
                      "actions": [
                        {
                          "label": "Edit",
                          "event": "EDIT"
                        },
                        {
                          "label": "Delete",
                          "event": "DELETE",
                          "variant": "danger"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "Viewing",
                "to": "Browsing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ]
                ]
              },
              {
                "from": "Viewing",
                "to": "Editing",
                "event": "EDIT",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Task",
                      "fields": [
                        "title",
                        "status",
                        "priority"
                      ],
                      "submitEvent": "SAVE",
                      "cancelEvent": "CANCEL"
                    }
                  ]
                ]
              },
              {
                "from": "Browsing",
                "to": "Editing",
                "event": "EDIT",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Task",
                      "fields": [
                        "title",
                        "status",
                        "priority"
                      ],
                      "submitEvent": "SAVE",
                      "cancelEvent": "CANCEL"
                    }
                  ]
                ]
              },
              {
                "from": "Editing",
                "to": "Browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Task",
                    "@entity.id",
                    "@payload.data"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "emit",
                    "INIT"
                  ]
                ]
              },
              {
                "from": "Editing",
                "to": "Browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "Editing",
                "to": "Browsing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "Browsing",
                "to": "Deleting",
                "event": "DELETE",
                "effects": [
                  [
                    "set",
                    "@entity.id",
                    "@payload.id"
                  ],
                  [
                    "render-ui",
                    "overlay",
                    {
                      "type": "modal",
                      "title": "Confirm Delete",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "body",
                          "text": "Are you sure you want to delete this task? This action cannot be undone.",
                          "color": "var(--color-foreground)"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "end",
                          "children": [
                            {
                              "type": "button",
                              "label": "Cancel",
                              "event": "CANCEL",
                              "variant": "secondary"
                            },
                            {
                              "type": "button",
                              "label": "Delete",
                              "event": "CONFIRM_DELETE",
                              "variant": "danger"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "Viewing",
                "to": "Deleting",
                "event": "DELETE",
                "effects": [
                  [
                    "render-ui",
                    "overlay",
                    {
                      "type": "modal",
                      "title": "Confirm Delete",
                      "children": [
                        {
                          "type": "typography",
                          "variant": "body",
                          "text": "Are you sure you want to delete this task? This action cannot be undone.",
                          "color": "var(--color-foreground)"
                        },
                        {
                          "type": "stack",
                          "direction": "horizontal",
                          "gap": "md",
                          "justify": "end",
                          "children": [
                            {
                              "type": "button",
                              "label": "Cancel",
                              "event": "CANCEL",
                              "variant": "secondary"
                            },
                            {
                              "type": "button",
                              "label": "Delete",
                              "event": "CONFIRM_DELETE",
                              "variant": "danger"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "Deleting",
                "to": "Browsing",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Task",
                    "@entity.id"
                  ],
                  [
                    "render-ui",
                    "overlay",
                    null
                  ],
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "emit",
                    "INIT"
                  ]
                ]
              },
              {
                "from": "Deleting",
                "to": "Browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "overlay",
                    null
                  ]
                ]
              },
              {
                "from": "Deleting",
                "to": "Viewing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "overlay",
                    null
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "TasksPage",
          "path": "/tasks",
          "viewType": "list",
          "isInitial": true,
          "entity": "Task",
          "traits": [
            {
              "ref": "TaskInteraction"
            }
          ]
        }
      ],
      "domainContext": {
        "request": "Generate an Orbital schema for a task management app with Entity: Task with fields: title (string, required), status (enum: pending/active/done), priority (enum: low/medium/high). Requirements: List view with search and actions (view, edit, delete), Modal form for creating tasks, Use atomic composition with stack layouts, Include stats/overview section showing counts",
        "requestFragment": "Task management app with list view, search, actions, modal forms, and stats overview",
        "category": "business",
        "vocabulary": {
          "item": "Task",
          "create": "New Task",
          "delete": "Delete Task"
        }
      },
      "design": {
        "style": "modern",
        "uxHints": {
          "flowPattern": "crud-cycle",
          "listPattern": "entity-table",
          "formPattern": "modal"
        }
      },
      "emits": [],
      "listens": []
    }
  ]
}