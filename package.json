{
  "name": "@almadar-io/skills",
  "version": "2.16.6",
  "description": "AI skill generators and prompts for Orbital schema generation",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./generators": {
      "import": "./dist/generators/index.js",
      "types": "./dist/generators/index.d.ts"
    },
    "./prompts": {
      "import": "./dist/prompts/index.js",
      "types": "./dist/prompts/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "generate": "pnpm build && tsx scripts/generate.ts",
    "generate:list": "pnpm build && tsx scripts/generate.ts list",
    "generate:preview": "pnpm build && tsx scripts/generate.ts preview",
    "install:skills": "pnpm build && tsx scripts/install.ts",
    "install:check": "tsx scripts/install.ts --check",
    "install:clean": "pnpm build && tsx scripts/install.ts --clean",
    "validate": "pnpm build && tsx scripts/validate.ts",
    "sync": "pnpm build && tsx scripts/sync.ts",
    "sync:dry": "pnpm build && tsx scripts/sync.ts --dry-run",
    "clean": "rm -rf .skills dist",
    "eval": "tsx evals/cli.ts",
    "eval:basic": "tsx evals/cli.ts --tags basic",
    "eval:edge": "tsx evals/cli.ts --tags edge-case",
    "eval:compare": "tsx evals/cli.ts compare",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@almadar/core": ">=4.2.0",
    "@almadar/llm": ">=2.5.1",
    "@almadar/patterns": ">=2.8.7",
    "@almadar/std": ">=5.2.0",
    "commander": "^12.0.0",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@almadar/eslint-plugin": ">=2.7.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "8.56.0",
    "dotenv": "^16.4.0",
    "eslint": "10.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-skills.git",
    "directory": "docs/packages/skills"
  },
  "license": "BSL-1.1",
  "keywords": [
    "almadar",
    "orbital",
    "skills",
    "ai",
    "prompts",
    "generation"
  ],
  "homepage": "https://github.com/almadar-io/almadar#readme",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
